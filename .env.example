# TAVUS_API_KEY and ANTHROPIC_API_KEY are NOT set here anymore — enter them
# through the app itself (Settings, top right) after starting the server.
# They're stored locally in data/keys.json (gitignored), never in this file.

PORT=3000

# A public HTTPS URL that reaches this server — required for trivia tool calls
# and Interactive Card taps, since Tavus's servers deliver those via webhook
# and can't reach localhost. For local testing, run `ngrok http 3000` and set
# this to the printed https://*.ngrok-free.app URL.
PUBLIC_BASE_URL=

# Shared secret Tavus signs tool-call webhook requests with (X-Tavus-Signature).
# Auto-generated into this file by scripts/upgrade-persona.js if left blank.
TAVUS_TOOL_WEBHOOK_SECRET=
